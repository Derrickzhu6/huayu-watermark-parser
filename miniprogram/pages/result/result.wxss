.container { padding: 12px; }
.header-bar { background: linear-gradient(135deg, #e74c3c, #2ecc71); padding: 24px 16px; text-align: center; border-radius: 14px; margin-bottom: 12px; }
.app-name { font-size: 22px; font-weight: 700; color: #fff; letter-spacing: 1px; }
.app-desc { font-size: 12px; color: rgba(255,255,255,0.7); margin-top: 6px; }
.card { background: #fff; border-radius: 12px; margin-bottom: 12px; box-shadow: 0 1px 4px rgba(0,0,0,0.06); overflow: hidden; }
.menu-item { display: flex; justify-content: space-between; align-items: center; padding: 15px 16px; border-bottom: 1px solid #f0f0f5; font-size: 14px; }
.menu-item:last-child { border-bottom: none; }
.menu-item:active { background: #f8f9fa; }
.menu-label { display: flex; align-items: center; gap: 8px; }
.menu-icon { font-size: 16px; }
.menu-value { font-size: 12px; color: #636e72; max-width: 55%; text-align: right; }
.arrow { font-size: 16px; color: #b2bec3; }
.disclaimer { padding: 16px; }
.disclaimer-title { font-size: 13px; font-weight: 600; color: #636e72; margin-bottom: 8px; }
.disclaimer-text { font-size: 11px; color: #b2bec3; line-height: 1.8; white-space: pre-line; }
.footer { text-align: center; font-size: 11px; color: #b2bec3; padding: 20px 0; }
.contact-row { padding: 12px 16px; text-align: center; font-size: 12px; color: #b2bec3; }
.contact-row text { margin: 0 4px; }
