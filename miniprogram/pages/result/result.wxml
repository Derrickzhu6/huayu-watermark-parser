<view class="container">
  <view class="header-bar">
    <view class="app-name">桦煜去水印</view>
    <view class="app-desc">图片 · 视频 · 格式转换</view>
  </view>

  <view class="card">
    <view class="menu-item" bindtap="copyLink">
      <view class="menu-label">
        <text class="menu-icon">🔗</text>
        <text>服务器地址</text>
      </view>
      <text class="menu-value">{{serverUrl}}</text>
    </view>
    <view class="menu-item">
      <view class="menu-label">
        <text class="menu-icon">📌</text>
        <text>版本</text>
      </view>
      <text class="menu-value">v1.0.0</text>
    </view>
  </view>

  <view class="card">
    <view class="menu-item" bindtap="onAbout">
      <view class="menu-label">
        <text class="menu-icon">📖</text>
        <text>关于我们</text>
      </view>
      <text class="arrow">›</text>
    </view>
    <view class="menu-item" bindtap="onPrivacy">
      <view class="menu-label">
        <text class="menu-icon">🔒</text>
        <text>隐私说明</text>
      </view>
      <text class="arrow">›</text>
    </view>
    <view class="menu-item" bindtap="onFeedback">
      <view class="menu-label">
        <text class="menu-icon">💬</text>
        <text>意见反馈</text>
      </view>
      <text class="arrow">›</text>
    </view>
  </view>

  <view class="card disclaimer">
    <view class="disclaimer-title">免责声明</view>
    <text class="disclaimer-text">
      1. 本工具仅用于个人学习研究，不得用于侵权用途。

      2. 上传的文件处理完成后自动删除，不会存储在服务器上。

      3. 用户自行承担使用本工具的法律责任。
    </text>
  </view>

  <view class="contact-row">
    <text>📧 huayu@example.com</text>
    <text>|</text>
    <text>Copyright © 2024 桦煜科技</text>
  </view>
</view>
