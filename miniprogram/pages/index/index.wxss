.container {
  padding: 12px;
}
.card {
  background: #fff;
  border-radius: 12px;
  padding: 16px;
  margin-bottom: 12px;
  box-shadow: 0 1px 4px rgba(0,0,0,0.06);
}
.card-title {
  font-size: 16px;
  font-weight: 600;
  margin-bottom: 4px;
}
.card-desc {
  font-size: 12px;
  color: #636e72;
  margin-bottom: 12px;
}
.input {
  width: 100%;
  min-height: 80px;
  border: 1.5px solid #e0e0e0;
  border-radius: 8px;
  padding: 10px;
  font-size: 13px;
  box-sizing: border-box;
  margin-bottom: 10px;
}
.btn-primary {
  width: 100%;
  padding: 10px;
  background: linear-gradient(135deg, #e74c3c, #2ecc71);
  color: #fff;
  border: none;
  border-radius: 8px;
  font-size: 14px;
  font-weight: 600;
}
.video {
  width: 100%;
  border-radius: 8px;
  margin-bottom: 8px;
}
.result-info {
  padding: 4px 0;
}
.title {
  font-size: 13px;
  font-weight: 500;
  display: block;
  margin-bottom: 4px;
}
.platform {
  font-size: 11px;
  color: #636e72;
}
.btn-download {
  width: 100%;
  padding: 8px;
  background: #e74c3c;
  color: #fff;
  border: none;
  border-radius: 8px;
  font-size: 13px;
  margin-top: 8px;
}
.footer {
  text-align: center;
  font-size: 11px;
  color: #b2bec3;
  padding: 20px 0;
}
