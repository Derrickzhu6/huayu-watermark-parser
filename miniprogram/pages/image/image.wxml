<view class="container">
  <view class="card">
    <view class="card-title">图片去水印</view>
    <view class="card-desc">上传图片后一键去水印，或用画笔涂抹指定区域</view>
    
    <button class="btn-upload" bindtap="onChooseImage" wx:if="{{!image}}">添加照片</button>
    
    <view wx:if="{{image}}" class="preview-wrap">
      <view class="image-wrap" id="imageWrap">
        <image src="{{image}}" class="preview-img" mode="widthFix" bindload="onImageLoaded"></image>
        <!-- 纯 view 触摸层，不用 canvas -->
        <view class="touch-layer {{brushMode ? '' : 'hidden'}}"
          catchtouchstart="onBrushStart" catchtouchmove="onBrushMove" catchtouchend="onBrushEnd"></view>
        <!-- 显示涂抹位置的标记点 -->
        <view wx:for="{{brushDots}}" wx:key="*this" class="brush-dot" style="left:{{item.x - 4}}px; top:{{item.y - 4}}px; width:{{brushSize}}px; height:{{brushSize}}px;"></view>
      </view>
      
      <view wx:if="{{brushMode}}" class="brush-tools">
        <text class="brush-label">画笔大小: {{brushSize}}</text>
        <slider class="brush-slider" min="3" max="30" value="{{brushSize}}" bindchange="onBrushSizeChange"></slider>
      </view>
      
      <view wx:if="{{brushMode && brushPts.length >= 2}}">
        <button class="btn-primary" bindtap="onBrushInpaint">开始修复</button>
      </view>
      
      <button class="btn-reselect" bindtap="onReset">重新选择</button>
    </view>
    
    <view wx:if="{{image}}" class="tools">
      <button class="btn-primary" bindtap="onToggleBrush">{{brushMode ? "关闭画笔" : "涂抹修复"}}</button>
      <button class="btn-primary" bindtap="onAutoInpaint" loading="{{processing}}">{{processing ? "处理中..." : "一键去水印"}}</button>
    </view>
    
    <view wx:if="{{resultImage}}" class="result-section">
      <image src="{{resultImage}}" class="preview-img" mode="widthFix"></image>
      <button class="btn-download" bindtap="onSaveImage">保存到相册</button>
      <button class="btn-secondary" bindtap="onReset">重新选择</button>
    </view>
  </view>
  
  <view class="footer">图片处理完成后自动删除，不会存储</view>
</view>
