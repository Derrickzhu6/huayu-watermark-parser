<view class="container">
  <view class="card">
    <view class="card-title">图片去水印</view>
    <view class="card-desc">上传图片后一键去水印，或用画笔涂抹指定区域</view>
    
    <button class="btn-upload" bindtap="onChooseImage" wx:if="{{!image}}">添加照片</button>
    
    <view wx:if="{{image}}" class="preview-wrap">
      <view class="image-canvas-wrap">
        <image id="mainImage" src="{{image}}" class="preview" mode="widthFix" bindload="onImageLoaded"></image>
        <canvas canvas-id="brushCanvas" class="brush-overlay {{brushMode ? '' : 'hidden'}}"
          width="{{canvasWidth}}" height="{{canvasHeight}}"
          catchtouchstart="onTouchStart" catchtouchmove="onTouchMove" catchtouchend="onTouchEnd"></canvas>
      </view>
      <view class="brush-tools" wx:if="{{brushMode}}">
        <text class="brush-label">画笔大小: {{brushSize}}</text>
        <slider class="brush-slider" min="3" max="30" value="{{brushSize}}" bindchange="onBrushSizeChange" showValue="{{false}}"></slider>
      </view>
      <button class="btn-reselect" bindtap="onReset">重新选择</button>
    </view>
    
    <view wx:if="{{image && !brushMode && !resultImage}}" class="tools">
      <button class="btn-primary" bindtap="onAutoInpaint" loading="{{processing}}">{{processing ? "处理中..." : "一键去水印"}}</button>
      <button class="btn-secondary" bindtap="onToggleBrush">{{brushMode ? "关闭画笔" : "涂抹修复"}}</button>
    </view>
    
    <view wx:if="{{brushMode && brushPtsCount >= 2}}" class="brush-submit-area">
      <button class="btn-primary" bindtap="onBrushSubmit">开始修复</button>
    </view>
    
    <view wx:if="{{resultImage}}" class="result-section">
      <image src="{{resultImage}}" class="preview" mode="widthFix"></image>
      <button class="btn-download" bindtap="onSaveImage">保存到相册</button>
      <button class="btn-secondary" bindtap="onReset">重新选择</button>
    </view>
  </view>
  
  <view class="footer">图片处理完成后自动删除，不会存储</view>
</view>
