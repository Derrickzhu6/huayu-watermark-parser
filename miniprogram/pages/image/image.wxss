.container { padding: 12px; }
.card { background: #fff; border-radius: 12px; padding: 16px; margin-bottom: 12px; box-shadow: 0 1px 4px rgba(0,0,0,0.06); }
.card-title { font-size: 16px; font-weight: 600; margin-bottom: 4px; }
.card-desc { font-size: 12px; color: #636e72; margin-bottom: 12px; }
.btn-upload { width: 100%; padding: 20px; background: #f8f9fa; border: 2px dashed #e0e0e0; border-radius: 10px; font-size: 14px; color: #636e72; text-align: center; }
.preview-wrap { margin-bottom: 8px; }
.image-wrap { position: relative; display: inline-block; width: 100%; line-height: 0; font-size: 0; }
.preview-img { width: 100%; border-radius: 8px; display: block; }
.touch-layer { position: absolute; top: 0; left: 0; width: 100%; height: 100%; border-radius: 8px; z-index: 10; }
.touch-layer.hidden { display: none; }
.touch-layer.active { background: rgba(231,76,60,0.05); }
.brush-dot { position: absolute; border-radius: 50%; background: rgba(231,76,60,0.6); z-index: 11; pointer-events: none; }
.debug-coord { position: absolute; bottom: 4px; left: 4px; z-index: 20; background: rgba(0,0,0,0.7); color: #fff; padding: 3px 6px; border-radius: 4px; font-size: 10px; pointer-events: none; }
.brush-tools { display: flex; align-items: center; margin-bottom: 6px; }
.brush-label { font-size: 12px; color: #636e72; white-space: nowrap; margin-right: 8px; }
.brush-slider { flex: 1; }
.btn-reselect { width: 100%; padding: 6px; background: #fff; color: #e74c3c; border: 1.5px solid #e74c3c; border-radius: 6px; font-size: 12px; text-align: center; margin-top: 6px; }
.tools { margin-top: 8px; }
.btn-primary { width: 100%; padding: 10px; background: linear-gradient(135deg, #e74c3c, #2ecc71); color: #fff; border: none; border-radius: 8px; font-size: 14px; font-weight: 600; margin-bottom: 8px; }
.btn-secondary { width: 100%; padding: 8px; background: #fff; color: #636e72; border: 1.5px solid #e0e0e0; border-radius: 8px; font-size: 13px; margin-bottom: 8px; }
.btn-download { width: 100%; padding: 10px; background: #e74c3c; color: #fff; border: none; border-radius: 8px; font-size: 14px; margin-top: 8px; }
.result-section { margin-top: 12px; }
.footer { text-align: center; font-size: 11px; color: #b2bec3; padding: 20px 0; }
